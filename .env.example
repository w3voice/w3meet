# ===========================================
# W3-Meet Environment Variables
# ===========================================
# Copy this file to .env:  cp .env.example .env
# All defaults work for local Docker development.
# For production: change ALL secrets to strong random values.
# ===========================================

# LiveKit — must match docker/livekit.yaml "keys" section
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880

# Redis — standard port from docker-compose
REDIS_URL=redis://localhost:6379

# MinIO — must match MINIO_ROOT_USER/PASSWORD in docker-compose
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RECORDINGS=recordings
MINIO_BUCKET_ARTIFACTS=artifacts

# Backend server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# TURN relay — must match static-auth-secret in docker/coturn.conf
TURN_SECRET=turnsecret
TURN_SERVER=turn:localhost:3478
TURN_TLS_SERVER=turns:localhost:5349
